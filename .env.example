# Example backend environment variables for local development
# Copy to `.env` and fill in the values (DO NOT commit secrets)

PORT=5000
# MongoDB Atlas connection string (use the SRV form or the standard URI)
# Example (SRV): mongodb+srv://<user>:<password>@cluster0.abcd.mongodb.net/DBNAME?retryWrites=true&w=majority
# Example (standard): mongodb://<user>:<password>@host1,host2,host3/DBNAME?ssl=true&replicaSet=...&authSource=admin
MONGODB_URI=

JWT_SECRET=replace_this_with_a_secure_random_string
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
